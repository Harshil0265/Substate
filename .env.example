# Database
MONGODB_URI=mongodb://localhost:27017/substate
# For production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/substate?retryWrites=true&w=majority

# Server
PORT=5000
NODE_ENV=development

# JWT Configuration - Professional Session Management
JWT_SECRET=your-secret-key-here-change-in-production-min-32-characters
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
JWT_REMEMBER_ME_EXPIRY=30d

# Email Configuration (Choose one method)
# Method 1: Gmail (recommended for development)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=SUBSTATE <your-email@gmail.com>

# Method 2: Custom SMTP (for production)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=SUBSTATE <noreply@yourdomain.com>

# OpenAI (for AI content generation - optional)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Razorpay (for payment processing - optional)
RAZORPAY_KEY_ID=rzp_test_your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Frontend (for local development)
VITE_API_URL=http://localhost:5000

# Production Frontend URL (for Vercel deployment)
# VITE_API_URL=https://your-app.vercel.app

